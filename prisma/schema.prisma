// Venym Search - Prisma Schema
// Rebranded from SearchHive

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String   @unique
  password_hash     String
  full_name         String?
  company           String?
  use_case          String?
  role              String   @default("user") // "user" or "admin"
  plan              String   @default("free")
  credits_remaining Int      @default(5000)
  stripe_customer_id String?
  subscription_id   String?
  subscription_status String?
  plan_type         String   @default("free")
  current_period_end DateTime?
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt

  // Relations
  api_keys     ApiKey[]
  api_requests ApiRequest[]
  payments     Payment[]
  blog_posts   BlogPost[]

  @@map("users")
}

model ApiKey {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  key_name     String
  api_key      String    @unique
  is_active    Boolean   @default(true)
  last_used_at DateTime?
  created_at   DateTime  @default(now())

  // Relations
  user         User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  api_requests ApiRequest[]

  @@map("api_keys")
}

model ApiRequest {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id       String    @db.Uuid
  api_key_id    String?   @db.Uuid
  endpoint      String
  method        String
  status_code   Int
  credits_used  Int
  request_data  Json?
  response_data Json?
  latency_ms         Int?
  backend_latency_ms Int?
  created_at         DateTime  @default(now())

  // Relations
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  api_key ApiKey? @relation(fields: [api_key_id], references: [id], onDelete: SetNull)

  @@map("api_requests")
}

model Payment {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                   String   @db.Uuid
  stripe_payment_intent_id  String   @unique
  amount                    Int
  credits_purchased         Int
  plan_name                 String
  status                    String   @default("pending")
  stripe_checkout_session_id String?
  created_at                DateTime @default(now())
  updated_at                DateTime @default(now()) @updatedAt

  // Relations
  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model BlogPost {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  slug        String   @unique
  content     String?
  excerpt     String?
  category    String?
  tags        String[]
  status      String   @default("DRAFT")
  author_id   String?  @db.Uuid
  featured_image_url String?
  seo_title   String?
  seo_description String?
  published_at DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  // Relations
  author User? @relation(fields: [author_id], references: [id], onDelete: SetNull)

  @@map("blog_posts")
}

model TrendingTopic {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  topic       String
  category    String?
  search_volume Int?
  trend_score Float?
  related_keywords String[]
  created_at  DateTime @default(now())

  @@map("trending_topics")
}

model ContentGenerationJob {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_type    String
  status      String   @default("PENDING")
  input_data  Json?
  output_data Json?
  error_message String?
  created_at  DateTime @default(now())
  completed_at DateTime?

  @@map("content_generation_jobs")
}

model BlogMetrics {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  post_id     String   @db.Uuid
  views       Int      @default(0)
  unique_visitors Int  @default(0)
  avg_time_on_page Float?
  bounce_rate Float?
  date        DateTime @default(now())

  @@map("blog_metrics")
}

model BlogCategory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  created_at  DateTime @default(now())

  @@map("blog_categories")
}

model SeoData {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  url         String   @unique
  title       String?
  description String?
  keywords    String[]
  canonical_url String?
  og_image    String?
  structured_data Json?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  @@map("seo_data")
}
